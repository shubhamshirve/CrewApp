# CrewBook backend — PRODUCTION environment variables
# Copy to backend/.env before running docker compose

# ── Required ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://mongodb:27017
DB_NAME=crewbook_db

# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME

# ── Environment ───────────────────────────────────────────────────────────────
ENV=production

# Restrict CORS to your domain only
CORS_ORIGINS=https://crew.mmpf.in

# ── Security ──────────────────────────────────────────────────────────────────
# Admin seed endpoint — generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_SEED_SECRET=CHANGE_ME
ADMIN_DEFAULT_PASSWORD=Admin@123

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=xxxx

# ── AI (Emergent Universal Key) ───────────────────────────────────────────────
EMERGENT_LLM_KEY=sk-emergent-xxxx

# ── Push Notifications (Web Push VAPID) ───────────────────────────────────────
# Generate: python3 -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@crewbook.in

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave blank to use mock email (logs to console only)
RESEND_API_KEY=

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOADS_DIR=/app/uploads
