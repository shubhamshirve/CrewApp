# Backend environment variables
# Copy this to .env and fill in your values

# MongoDB (use mongodb://mongodb:27017 for docker-compose, mongodb://localhost:27017 for local dev)
MONGO_URL=mongodb://localhost:27017
DB_NAME=crewbook_db

# CORS — set to your frontend domain in production
CORS_ORIGINS=*

# JWT — change this to a long random string in production
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_32_chars

# Razorpay — get from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Emergent LLM Key — for Gemini Flash AI features
EMERGENT_LLM_KEY=your_emergent_llm_key_here

# Referral reward amount in INR
REFERRAL_REWARD_AMOUNT=50
